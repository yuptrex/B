</div>

<div id="toast"></div>

<div id="screen-auth" class="screen active">
  <div style="position:relative;display:flex;flex-direction:column;align-items:center;width:min(430px,94vw);">
    <div class="mascot-wrap">
      <span class="mascot-icon">🧊</span>
      <div class="mascot-bubble">🎮 Let's play!</div>
    </div>
    <div class="ice-panel">
      <div class="panel-deco">❄</div>
      <div class="auth-title">❄️ Frozen Clash</div>
      <div class="auth-sub">🏔 Ice Kingdom Warriors 🏔</div>
      <div class="tabs">
        <button class="tab active" id="tab-in" onclick="swTab('in')">🧊 Sign In</button>
        <button class="tab" id="tab-up" onclick="swTab('up')">⭐ Join!</button>
      </div>
      <div id="auth-err" class="err-msg">❌ Oops! Check your details!</div>
