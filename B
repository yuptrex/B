    updateLobbyUI() {
        document.getElementById('lb-gold').textContent = this.userData.gold;
        document.getElementById('lb-grids').textContent = this.userData.grids;
        document.getElementById('lb-streak').textContent = this.userData.streak || 0;
        document.getElementById('lb-name').textContent = this.userData.username || "Commander";
    },

    async auth() {
        const email = document.getElementById('auth-email').value.trim(); 
        const pass = document.getElementById('auth-pass').value;
        const err = document.getElementById('auth-err');
        err.classList.remove('show');
        
        if(!email || !pass) {
            err.textContent = '📝 Please fill in both fields!';
            err.classList.add('show');
            return;
        }

        const btn = document.getElementById('btn-auth');
        btn.disabled = true;
        document.getElementById('auth-tx').textContent = 'Connecting...';
        
        try {
            const isSignUp = document.getElementById('tab-up').classList.contains('active');
            if (isSignUp) {
                await createUserWithEmailAndPassword(auth, email, pass);
            } else {
                await signInWithEmailAndPassword(auth, email, pass);
            }
        } catch(e) {
            err.textContent = '❌ Invalid Credentials or Error!';
            err.classList.add('show');
            btn.disabled = false;
            const isSignUp = document.getElementById('tab-up').classList.contains('active');
            document.getElementById('auth-tx').textContent = isSignUp ? 'JOIN THE BATTLE!' : 'ENTER ICE KINGDOM';
        }
    },

    initUser(user) {
        this.user = user;
        const userRef = ref(db, `users/${user.uid}`);
        onValue(userRef, (snap) => {
            if (snap.exists()) {
                this.userData = { ...this.userData, ...snap.val() }; 
                document.getElementById('name-in').value = this.userData.username || "";
            } else {
                const randomNum = Math.floor(1000 + Math.random() * 9000);
                this.userData = {
                    gold: 5000,
                    grids: 50,
                    streak: 0,
                    username: "commander" + randomNum
                };
                set(userRef, this.userData);
                document.getElementById('name-in').value = this.userData.username;
            }
            
            this.updateLobbyUI();
            if (engine.phase === 'lobby' || engine.phase === 'end_v') { 
                document.getElementById('loader').classList.add('hide'); 
                this.switchScreen('screen-lobby'); 
                engine.phase = 'lobby'; 
            }
        });
    },

    async logout() {
        try {
            await signOut(auth); this.user = null;
            document.getElementById('auth-email').value = ''; document.getElementById('auth-pass').value = '';
            this.switchScreen('screen-auth'); engine.phase = 'lobby';
            document.getElementById('btn-auth').disabled = false;
            document.getElementById('auth-tx').textContent = 'ENTER ICE KINGDOM';
        } catch (err) { toast("❌ Logout Failed"); }
    },

    openProfile() {
        document.getElementById('name-in').value = this.userData.username || "";
        document.getElementById('modal-profile').classList.add('show');
    },
    
    closeProfile() {
        document.getElementById('modal-profile').classList.remove('show');
    },

    saveName() {
        const nameInput = document.getElementById('name-in').value.trim() || "Commander";
        this.userData.username = nameInput;
        update(ref(db, `users/${this.user.uid}`), { username: nameInput });
        this.updateLobbyUI();
        this.closeProfile();
        toast('✅ Name saved: ' + nameInput); sfx.pop();
    },

    // LEADERBOARD LOGIC
    openLb() {
        document.getElementById('modal-lb').classList.add('show');
        this.loadRank('streak');
    },
    closeLb() {
        document.getElementById('modal-lb').classList.remove('show');
    },

    loadRank(category) {
        document.querySelectorAll('.rank-tab').forEach(t => t.classList.remove('active'));
        document.getElementById(`rt-${category}`).classList.add('active');
        
        const listEl = document.getElementById('rank-list');
        listEl.innerHTML = '<div style="text-align:center;padding:20px;color:#6080a0;font-weight:700;">❄️ Loading champions...</div>';

        get(ref(db, 'users')).then((snap) => {
            if (!snap.exists()) { listEl.innerHTML = '<div style="text-align:center;padding:20px;color:#6080a0;">No data found 😢</div>'; return; }
            let users = [];
            snap.forEach(childSnap => {
                users.push({ uid: childSnap.key, ...childSnap.val() });
            });
            
            users.sort((a, b) => {
                let valA = a[category] || 0; let valB = b[category] || 0;
                return valB - valA;
            });
            
            users = users.slice(0, 100);
            
            listEl.innerHTML = '';
            users.forEach((u, index) => {
                const isMe = u.uid === this.user.uid;
                const rankClass = index === 0 ? ' rk1' : '';
                const meClass = isMe ? ' isme' : '';
                
                const ic = { streak: '⚔️', grids: '🏰', gold: '💰' };
                let valStr = `${ic[category]} ${u[category] || 0}`;

                const div = document.createElement('div');
                div.className = `rk-item${rankClass}${meClass}`;
                
                let iconRank = `#${index + 1}`;
                if(index === 0) iconRank = '🥇'; else if(index===1) iconRank = '🥈'; else if(index===2) iconRank = '🥉';

                div.innerHTML = `
                    <div class="rk-num">${iconRank}</div>
                    <div class="rk-name">${u.username || 'Commander'} ${isMe ? '👈(YOU)' : ''}</div>
                    <div class="rk-val">${valStr}</div>
                `;
                listEl.appendChild(div);
            });
        }).catch(() => {
            listEl.innerHTML = '<div style="text-align:center;padding:20px;color:#e74c3c;">❌ Could not load!</div>';
        });
    },

    async findMatch() {
        if(document.getElementById('card-prac').classList.contains('active')) {
            toast('⚠️ Training coming soon! Try Live Battle!');
            return;
        }

        document.getElementById('mm-box').classList.add('show');
        const btn = document.getElementById('btn-mm'); btn.disabled = true;
        
        this.queueRef = ref(db, 'queue');
        const snap = await get(this.queueRef);
        const myName = this.userData.username || "Commander";

        if (snap.exists() && snap.val().uid !== this.user.uid) {
            const hostUid = snap.val().uid;
            this.matchId = hostUid + "_" + this.user.uid;
            this.myRole = 'red'; 
            await set(ref(db, `matches/${this.matchId}`), {
                blue: hostUid, red: this.user.uid,
                redName: myName,
                status: 'placement', startTime: Date.now(),
                blueReady: false, redReady: false,
                blueBoard: Array(40).fill(null), redBoard: Array(40).fill(null)
            });
            await remove(this.queueRef); this.setupGame();
        } else {
            this.myRole = 'blue';
            await set(this.queueRef, { uid: this.user.uid, time: Date.now() });
            this.queueDisconnectRef = onDisconnect(this.queueRef); this.queueDisconnectRef.remove();
            
            document.getElementById('mm-sub').textContent = 'Waiting for another player...';
            
            const matchQuery = ref(db, 'matches');
            onValue(matchQuery, (mSnap) => {
                mSnap.forEach(child => {
                    if (child.val().blue === this.user.uid && child.val().status === 'placement' && !this.matchId) {
                        this.matchId = child.key;
                        if(this.queueDisconnectRef) this.queueDisconnectRef.cancel();
                        remove(this.queueRef);
                        update(ref(db, `matches/${this.matchId}`), { blueName: myName });
                        this.setupGame();
                    }
                });
            });
        }
    },

    async cancelMatch() {
        if (this.queueRef) { if(this.queueDisconnectRef) this.queueDisconnectRef.cancel(); await remove(this.queueRef); this.queueRef = null; }
        document.getElementById('mm-box').classList.remove('show');
        document.getElementById('btn-mm').disabled = false;
    },

    syncOpponentEntities() {
        const enemyRole = this.myRole === 'blue' ? 'red' : 'blue';
        const rowOffset = enemyRole === 'red' ? 0 : 5;
        engine.entities = engine.entities.filter(e => !(e.team === enemyRole && e.type !== 'main'));
        for(let i = 0; i < 40; i++) {
            let item = this.oppBoard[i];
            if (item) {
                let localR = Math.floor(i / COLS); let c = i % COLS; let r = localR + rowOffset;
                if (!((enemyRole === 'red' && localR === 0 && (c===3||c===4)) || (enemyRole === 'blue' && localR === 4 && (c===3||c===4)))) {
                    engine.entities.push(new Entity(r, c, enemyRole, item));
                }
            }
        }
    },

    setupGame() {
        document.getElementById('mm-box').classList.remove('show');
        document.getElementById('btn-mm').disabled = false;
        
        this.switchScreen('screen-game'); 
        document.getElementById('gc-gold').textContent = this.userData.gold;
        document.getElementById('shop-bar').style.display = 'flex';
        document.getElementById('str-hud').classList.remove('show');
        document.getElementById('blog').classList.remove('show');
        document.getElementById('blog').innerHTML = '';
        document.getElementById('btn-ready').textContent = "⚡ READY!";
        document.getElementById('btn-ready').disabled = false;
        document.getElementById('ready-hint').textContent = 'Tap when set!';
        document.getElementById('g-echip').style.display = 'block';
        document.getElementById('gc-phase').textContent = 'Placement Phase';
        document.getElementById('gc-phase').style.color = '';
        document.getElementById('ptip').classList.add('show');
        document.getElementById('my-st').textContent = 'Placing units...';
        document.getElementById('enemy-st').textContent = 'Setting up...';
        
        this.myBoard = Array(40).fill(null); this.oppBoard = Array(40).fill(null);
        
        engine.startPlacement();
        engine.flipY = (this.myRole === 'red');
        engine.resize();
        
        const matchRef = ref(db, `matches/${this.matchId}`);
        this.matchDisconnectRef = onDisconnect(matchRef);
        this.matchDisconnectRef.update({ status: 'abandoned', leaver: this.myRole });

        onValue(matchRef, async (snap) => {
            const data = snap.val(); if (!data) return;

            const enemyRole = this.myRole === 'blue' ? 'red' : 'blue';

            if (data.status === 'abandoned') {
                if (data.leaver !== this.myRole && engine.phase !== 'end' && engine.phase !== 'end_v') {
                    engine.triggerGameEndLocal(this.myRole, "❄️ OPPONENT FLED!");
                }
                return;
            }

            if (data.status === 'finished' && engine.phase !== 'end_v') {
                engine.triggerGameEndLocal(data.winnerRole, data.endReason);
            }

            if (data[`${enemyRole}Board`]) {
                this.oppBoard = [...data[`${enemyRole}Board`]];
                if (engine.phase === 'placement') this.syncOpponentEntities();
            }

            if (data[`${enemyRole}Ready`]) {
                document.getElementById('enemy-st').textContent = "⚡ READY!";
                document.getElementById('ec-v').textContent = "Enemy is ready to fight!";
                addLog('❄️ Enemy locked in!', 'info');
            }

            if (data.status === 'placement' && data.blueReady && data.redReady) {
                if (this.myRole === 'red') await update(matchRef, { status: 'battle' });
            }

            if (data.status === 'battle' && engine.phase === 'placement') {
                this.triggerBattle(data.redBoard, data.blueBoard);
            }
        });

        let startTime = Date.now();
        this.timerInterval = setInterval(() => {
            if (engine.phase === 'placement') {
                const elapsed = Math.floor((Date.now() - startTime) / 1000);
                let timeLeft = Math.max(0, 120 - elapsed);
                const tEl = document.getElementById('gc-timer');
                tEl.textContent = timeLeft;
                tEl.classList.toggle('urgent', timeLeft <= 15);
                if (timeLeft <= 0) { clearInterval(this.timerInterval); this.declareReady(); }
            }
        }, 250);
        
        toast('❄️ Welcome to the Ice Arena! Place your units!');
    },

    selectUnit(type, cost) {
        document.querySelectorAll('.shop-card').forEach(el => el.classList.remove('sel'));
        document.getElementById(`shop-${type}`).classList.add('sel');
        this.selectedUnit = type; this.selectedCost = cost;
        document.getElementById('ptip').classList.add('show');
        sfx.pop();
        
        const nm = {soldier: '⚔️ Soldier', barrier: '🧊 Ice Wall', defense: '🔫 Cannon', arrow: '🏹 Archer'};
        toast(`${nm[type]} selected! Tap your blue zone!`);
    },

    async placeUnit(index, r, c) {
        if (this.userData.gold < this.selectedCost) {
            toast('💰 Not enough gold!');
            engine.floatingTexts.push(new FloatingText((c*TILE_SIZE)+engine.offsetX, (r*TILE_SIZE)+engine.offsetY, "No gold! 💰", "#e74c3c", 15, true));
            return;
        }
        this.userData.gold -= this.selectedCost;
        document.getElementById('gc-gold').textContent = this.userData.gold;
        this.myBoard[index] = this.selectedUnit;
        
        engine.entities = engine.entities.filter(e => !(e.team === gameApp.myRole && Math.round((e.y-engine.offsetY)/TILE_SIZE) === r && Math.round((e.x-engine.offsetX)/TILE_SIZE) === c && e.type !== 'main'));
        engine.entities.push(new Entity(r, c, gameApp.myRole, this.selectedUnit));
        
        engine.spawnParticles(c*TILE_SIZE+engine.offsetX+TILE_SIZE/2, r*TILE_SIZE+engine.offsetY+TILE_SIZE/2, '#ffe066', 7, 3, 'glow');
        addLog(`Placed ${this.selectedUnit} ❄️`, 'deploy');
        sfx.place();
        
        await update(ref(db, `matches/${this.matchId}`), { [`${this.myRole}Board`]: this.myBoard });
        await update(ref(db, `users/${this.user.uid}`), { gold: this.userData.gold });
    },

    async declareReady() {
        clearInterval(this.timerInterval);
        document.getElementById('btn-ready').textContent = "⏳ Waiting...";
        document.getElementById('btn-ready').disabled = true;
        document.getElementById('ready-hint').textContent = 'Waiting for opponent!';
        document.getElementById('my-st').textContent = '⚡ LOCKED IN!';
        document.getElementById('ptip').classList.remove('show');
        
        toast('✅ Formation locked! Waiting for opponent...');
        sfx.pop();
        
        await update(ref(db, `matches/${this.matchId}`), { [`${this.myRole}Ready`]: true });
    },

    triggerBattle(redBoard, blueBoard) {
        this.redBoardData = redBoard; this.blueBoardData = blueBoard;
        document.getElementById('shop-bar').style.display = 'none';
        document.getElementById('ptip').classList.remove('show');
        document.getElementById('g-echip').style.display = 'none';
        
        document.getElementById('gc-phase').textContent = "Scouting Enemy... 👀";
        
        engine.prepareBattle(redBoard, blueBoard);
        canvas.classList.add('zoom-battle');
        
        let countdown = 5; document.getElementById('gc-timer').textContent = countdown;
        const revealInterval = setInterval(() => {
            countdown--;
            if (countdown > 0) { document.getElementById('gc-timer').textContent = countdown; } 
            else {
                clearInterval(revealInterval);
                document.getElementById('gc-phase').textContent = "⚔️ LIVE BATTLE!";
                document.getElementById('gc-phase').style.color = "#e74c3c";
                document.getElementById('gc-timer').textContent = "⚔️";
                document.getElementById('str-hud').classList.add('show');
                document.getElementById('blog').classList.add('show');
                engine.phase = 'battle';
                addLog('⚔️ BATTLE STARTED! Fight hard!', 'info');
                toast('⚔️ BATTLE BEGINS! Good luck! ❄️');
                setTimeout(() => { if(engine.phase === 'battle') engine.triggerGameEnd('draw', "⏰ Time ran out!"); }, 120000);
            }
        }, 1000);
    },

    async endGame(winnerRole, reason) {
        engine.phase = 'end_v';
        let isWin = winnerRole === this.myRole;
        let isDraw = winnerRole === 'draw';
        
        if (this.matchDisconnectRef) this.matchDisconnectRef.cancel();

        let totalPot = this.getSpent(this.myBoard) + this.getSpent(this.myRole === 'blue' ? this.redBoardData : this.blueBoardData);

        const surv = engine.entities.filter(e => !e.isDead && e.type !== 'main').length;
        
        const em = document.getElementById('res-em');
        const tt = document.getElementById('res-ttl');
        const gr = document.getElementById('res-gold');
        const grd = document.getElementById('res-grid');
        
        document.getElementById('res-surv').textContent = surv;
        document.getElementById('res-reason').textContent = reason;
        
        tt.className = 'res-ttl'; gr.className = 'res-v'; grd.className = 'res-v';
        
        const rsEl = document.getElementById('res-snow');
        rsEl.innerHTML = '';
        for(let i=0; i<14; i++){
            const f = document.createElement('div');
            f.className = 'res-flake';
            f.textContent = ['❄️','⛄','🌨','🏔️','🧊'][Math.floor(Math.random()*5)];
            f.style.cssText = `left:${Math.random()*100}%;animation-duration:${Math.random()*4+3}s;animation-delay:${Math.random()*2}s;font-size:${Math.random()*1.8+0.7}rem;`;
            rsEl.appendChild(f);
        }

        if (isDraw) {
            em.textContent = '🤝'; tt.textContent = 'DRAW!'; tt.classList.add('draw');
            gr.textContent = '+0'; gr.classList.add('neu');
            grd.textContent = '±0'; grd.classList.add('neu');
        } else if (isWin) {
            em.textContent = '🏆'; tt.textContent = 'VICTORY!'; tt.classList.add('win');
            gr.textContent = `+${totalPot}`; gr.classList.add('pos');
            grd.textContent = '+5'; grd.classList.add('pos');
            this.userData.gold += totalPot; this.userData.grids += 5; this.userData.streak = (this.userData.streak || 0) + 1;
        } else {
            em.textContent = '💀'; tt.textContent = 'DEFEAT!'; tt.classList.add('loss');
            gr.textContent = '+0'; gr.classList.add('neg');
            grd.textContent = '-0'; grd.classList.add('neg');
            this.userData.streak = 0;
        }

        await update(ref(db, `users/${this.user.uid}`), this.userData);
        if(this.myRole === 'blue') await remove(ref(db, `matches/${this.matchId}`));

        document.getElementById('result-ov').classList.add('show');
    },

    returnToLobby() {
        document.getElementById('result-ov').classList.remove('show');
        document.getElementById('screen-game').classList.remove('active');
        document.getElementById('str-hud').classList.remove('show');
        document.getElementById('blog').classList.remove('show');
        
        document.getElementById('gc-phase').textContent = 'Placement Phase';
        document.getElementById('gc-phase').style.color = '';
        document.getElementById('gc-timer').textContent = '120';
        document.getElementById('gc-timer').classList.remove('urgent');
        document.getElementById('enemy-st').textContent = 'Setting up...';
        document.getElementById('my-st').textContent = 'Placing units...';
        document.getElementById('btn-mm').disabled = false;
        
        this.matchId = null; this.myRole = null; 
        canvas.classList.remove('zoom-battle');
        engine.phase = 'lobby';
        
        this.updateLobbyUI();
        this.switchScreen('screen-lobby');
    }
};

onAuthStateChanged(auth, user => {
    const tips = ['🌨 Loading snow particles...','🏔 Painting mountains...','🧊 Freezing the battlefield...','⛄ Waking up the yetis...','❄️ Almost ready to play!'];
    let ti = 0;
    const tEl = document.getElementById('ld-tip');
    const tIv = setInterval(() => {
        ti = (ti+1) % tips.length;
        tEl.textContent = tips[ti];
    }, 600);
    
    if(user) {
        gameApp.initUser(user);
        clearInterval(tIv);
    } else {
        setTimeout(() => {
            document.getElementById('loader').classList.add('hide');
            gameApp.switchScreen('screen-auth');
            clearInterval(tIv);
        }, 2200);
    }
});

window.gameApp = gameApp;
</script>
</body>
</html>
