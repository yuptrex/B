const ROWS = 5; 
const TOTAL_ROWS = ROWS * 2; 
let BOARD_W = COLS * TILE_SIZE;
let BOARD_H = TOTAL_ROWS * TILE_SIZE;

class Particle {
    constructor(x, y, color, speed = 2, size = 3, type = 'normal') {
        this.x = x; this.y = y;
        this.vx = (Math.random() - 0.5) * speed * 2;
        this.vy = (Math.random() - 0.5) * speed * 2;
        this.color = color;
        this.life = 1.0;
        this.decay = Math.random() * 0.05 + 0.02;
        this.size = size;
        this.type = type; 
        this.gravity = type === 'fire' ? 0.08 : 0;
        this.rotation = Math.random() * Math.PI * 2;
    }
    update() { 
        this.x += this.vx; this.y += this.vy; this.vy += this.gravity;
        this.life -= this.decay; this.rotation += 0.1;
    }
    draw(ctx, offsetX, offsetY) {
        if (this.life <= 0) return;
        ctx.globalAlpha = this.life;
        ctx.fillStyle = this.color;
        if (this.type === 'spark') {
            ctx.fillRect(this.x + offsetX - this.size/2, this.y + offsetY - this.size/2, this.size, this.size);
        } else if (this.type === 'glow') {
            ctx.shadowColor = this.color; ctx.shadowBlur = 20;
            ctx.beginPath(); ctx.arc(this.x + offsetX, this.y + offsetY, this.size, 0, Math.PI * 2); ctx.fill();
            ctx.shadowBlur = 0;
        } else {
            ctx.beginPath(); ctx.arc(this.x + offsetX, this.y + offsetY, this.size, 0, Math.PI * 2); ctx.fill();
        }
        ctx.globalAlpha = 1.0;
    }
}

class Projectile {
    constructor(x, y, vx, vy, damage, team, type = 'arrow') {
        this.x = x; this.y = y; this.vx = vx; this.vy = vy; this.damage = damage;
        this.team = team; this.type = type; this.life = 120;
        this.trail = []; this.angle = Math.atan2(vy, vx);
        this.glowIntensity = 1.0;
    }
    update(engine) {
        this.trail.push({x: this.x, y: this.y});
        if (this.trail.length > 12) this.trail.shift();
        this.x += this.vx; this.y += this.vy; this.life--;
        this.glowIntensity = Math.sin(Date.now() / 80) * 0.3 + 0.7;

        for (let i = engine.entities.length - 1; i >= 0; i--) {
            const e = engine.entities[i];
            if (e.team !== this.team && !e.isDead) {
                const dx = e.x - this.x; const dy = e.y - this.y;
                if (Math.hypot(dx, dy) < 18) {
                    e.takeDamage(this.damage, engine);
                    const pColor = (this.team === gameApp.myRole) ? '#a8d8ff' : '#ffb8b8';
                    engine.spawnParticles(this.x, this.y, pColor, 12, 4, 'spark');
                    this.life = 0; return;
                }
            }
        }
    }
    draw(ctx, offsetX, offsetY) {
        if (this.life <= 0) return;
        const px = this.x + offsetX; const py = this.y + offsetY;
        const isMe = (this.team === gameApp.myRole);
        const teamColor = isMe ? '#1a7fd4' : '#e74c3c';

        ctx.globalAlpha = 0.6; ctx.strokeStyle = teamColor; ctx.lineWidth = 3;
        ctx.beginPath();
        this.trail.forEach((p, i) => {
            if (i === 0) ctx.moveTo(p.x + offsetX, p.y + offsetY);
            else ctx.lineTo(p.x + offsetX, p.y + offsetY);
        });
        ctx.stroke(); ctx.globalAlpha = 1.0;

        ctx.save(); ctx.translate(px, py); ctx.rotate(this.angle);
        ctx.shadowColor = isMe ? '#6ab8ff' : '#ff9090'; ctx.shadowBlur = 15 * this.glowIntensity;
        ctx.fillStyle = this.type === 'arrow' ? '#ffe066' : '#aabbc0';
        ctx.beginPath(); ctx.moveTo(12, 0); ctx.lineTo(-8, -8); ctx.lineTo(-8, 8); ctx.fill();
        ctx.restore();
    }
}

class FloatingText {
    constructor(x, y, text, color, size = 16, crit = false) {
        this.x = x; this.y = y; this.text = text; this.color = color;
        this.life = 1.0; this.vy = crit ? -2.5 : -1.2; this.size = size; this.crit = crit;
    }
    update() { this.y += this.vy; this.life -= 0.022; }
    draw(ctx, offsetX, offsetY) {
        if(this.life <= 0) return;
        ctx.globalAlpha = this.life; ctx.fillStyle = this.color; 
        ctx.font = `${this.crit ? 'bold ' : ''}${this.size}px 'Nunito'`; ctx.textAlign = 'center';
        ctx.shadowColor = this.color; ctx.shadowBlur = this.crit ? 12 : 6;
        ctx.fillText(this.text, this.x + offsetX, this.y + offsetY);
        ctx.shadowBlur = 0; ctx.globalAlpha = 1.0;
    }
}

class Entity {
    constructor(r, c, team, type) {
        this.team = team; this.type = type;
        this.x = c * TILE_SIZE + TILE_SIZE/2; this.y = r * TILE_SIZE + TILE_SIZE/2;
        this.vx = 0; this.vy = 0; this.target = null; this.isDead = false;
        this.animationFrame = 0; this.bob = 0; this.angle = 0;
        
        switch(type) {
            case 'main': this.hp = 2000; this.maxHp = 2000; this.damage = 0; this.range = 0; this.speed = 0; this.cooldownMax = 0; break;
            case 'barrier': this.hp = 800; this.maxHp = 800; this.damage = 0; this.range = 0; this.speed = 0; this.cooldownMax = 0; break;
            case 'defense': this.hp = 400; this.maxHp = 400; this.damage = 40; this.range = 180; this.speed = 0; this.cooldownMax = 90; break;
            case 'soldier': this.hp = 150; this.maxHp = 150; this.damage = 28; this.range = 32; this.speed = 1.35; this.cooldownMax = 45; break;
            case 'arrow': this.hp = 55; this.maxHp = 55; this.damage = 65; this.range = 320; this.speed = 2.8; this.cooldownMax = 180; break;
        }
        this.cooldown = 0; this.velFriction = 0.92; this.hitFlash = 0;
    }

    update(engine) {
        if (this.isDead || engine.phase !== 'battle') return;
        this.animationFrame = (this.animationFrame + 0.18) % 4;
        this.bob = Math.sin(this.animationFrame * Math.PI) * 3;
        if (this.hitFlash > 0) this.hitFlash--;

        if (!this.target || this.target.isDead) {
            let minDist = Infinity; let newTarget = null;
            engine.entities.forEach(e => {
                if (e.team !== this.team && !e.isDead) {
                    let dist = Math.hypot(e.x - this.x, e.y - this.y);
                    if (e.type === 'main') dist *= 0.65;
                    if (dist < minDist) { minDist = dist; newTarget = e; }
                }
            });
            this.target = newTarget;
        }

        if (this.target && this.speed > 0) {
            let dx = this.target.x - this.x; let dy = this.target.y - this.y;
            let dist = Math.hypot(dx, dy);

            if (dist > this.range) {
                const desiredVx = (dx / dist) * this.speed; const desiredVy = (dy / dist) * this.speed;
                this.vx = this.vx * this.velFriction + desiredVx * 0.18;
                this.vy = this.vy * this.velFriction + desiredVy * 0.18;
                
                engine.entities.forEach(other => {
                    if (other !== this && other.team === this.team && !other.isDead && other.speed > 0) {
                        let odx = other.x - this.x; let ody = other.y - this.y;
                        let odist = Math.hypot(odx, ody);
                        if (odist < 28 && odist > 0) { this.vx -= (odx / odist) * 1.4; this.vy -= (ody / odist) * 1.4; }
                    }
                });

                this.x += this.vx; this.y += this.vy; this.angle = Math.atan2(this.vy, this.vx);
            } else if (dist <= this.range) {
                if (this.cooldown <= 0) {
                    this.cooldown = this.cooldownMax;
                    if (this.type === 'soldier') {
                        sfx.playSoldierAttack();
                        this.target.takeDamage(this.damage, engine);
                        engine.spawnParticles(this.target.x, this.target.y, '#ffe066', 8, 3);
                    } else if (this.type === 'defense' || this.type === 'arrow') {
                        if(this.type === 'defense') sfx.playCannonFire();
                        else sfx.playArrowFire();
                        const px = this.x + Math.cos(this.angle) * 12; const py = this.y + Math.sin(this.angle) * 12;
                        const pdx = this.target.x - px; const pdy = this.target.y - py;
                        const pdist = Math.hypot(pdx, pdy) || 1;
                        const pSpeed = this.type === 'arrow' ? 7.5 : 5.2;
                        const pvx = (pdx / pdist) * pSpeed; const pvy = (pdy / pdist) * pSpeed;
                        engine.projectiles.push(new Projectile(px, py, pvx, pvy, this.damage, this.team, this.type === 'arrow' ? 'arrow' : 'cannon'));
                    }
                }
            }
        }
        if (this.cooldown > 0) this.cooldown--;
    }

    takeDamage(amt, engine) {
        this.hp -= amt;
        this.hitFlash = 6;
        const isCrit = Math.random() > 0.85;
        engine.floatingTexts.push(new FloatingText(this.x, this.y - 20, `-${Math.floor(amt)}`, isCrit ? '#ff6b35' : '#e74c3c', isCrit ? 22 : 16, isCrit));
        if (this.hp <= 0) {
            this.isDead = true;
            const pColor = (this.team === gameApp.myRole) ? '#a8d8ff' : '#ffb8b8';
            engine.spawnParticles(this.x, this.y, pColor, 28, 6, this.type === 'main' ? 'fire' : 'normal');
            
            if (this.type === 'main') {
                const winningTeam = (this.team === 'blue') ? 'red' : 'blue';
                engine.triggerGameEnd(winningTeam, "BASE CONQUERED!");
                addLog(this.type.toUpperCase() + ' defeated! ❄', 'kill');
            }
        }
    }

    draw(ctx, offsetX, offsetY) {
        if (this.isDead) return;
        let px = this.x + offsetX; 
        let py = this.y + offsetY + this.bob;
        
        const isMe = (this.team === gameApp.myRole);
        const tc = isMe ? '#1a7fd4' : '#e74c3c';
        const fl = this.hitFlash > 0;
        
        ctx.globalAlpha = 0.22;
        ctx.fillStyle = 'rgba(0,50,120,0.5)';
        ctx.beginPath(); ctx.ellipse(px, py + TILE_SIZE/3, TILE_SIZE/3, TILE_SIZE/7, 0, 0, Math.PI*2); ctx.fill();
        ctx.globalAlpha = 1.0;

        ctx.lineWidth = 2.5;
        if (this.type === 'main') {
            const hw = TILE_SIZE * 0.82;
            ctx.shadowColor = tc; ctx.shadowBlur = fl ? 18 : 9;
            ctx.fillStyle = fl ? '#fff' : (isMe ? '#ddf0ff' : '#ffe8e8');
            ctx.strokeStyle = tc;
            if (ctx.roundRect) {
                ctx.beginPath(); ctx.roundRect(px - hw/2, py - hw/2, hw, hw, 9); ctx.fill(); ctx.stroke();
            } else {
                ctx.fillRect(px - hw/2, py - hw/2, hw, hw); ctx.strokeRect(px - hw/2, py - hw/2, hw, hw);
            }
            ctx.shadowBlur = 0;
            ctx.font = `${TILE_SIZE * 0.65}px Arial`; ctx.textAlign = 'center'; ctx.fillText('🏰', px, py+9);
        } else if (this.type === 'barrier') {
            ctx.shadowColor = fl ? '#fff' : '#a8d8ff'; ctx.shadowBlur = fl ? 13 : 5;
            ctx.fillStyle = fl ? '#fff' : 'rgba(175,228,255,0.85)';
            ctx.strokeStyle = 'rgba(100,180,255,0.75)'; ctx.lineWidth = 2.2;
            const hw = TILE_SIZE * 0.4;
            if (ctx.roundRect) {
                ctx.beginPath(); ctx.roundRect(px - hw, py - hw, hw*2, hw*2, 5); ctx.fill(); ctx.stroke();
            } else {
                ctx.fillRect(px - hw, py - hw, hw*2, hw*2); ctx.strokeRect(px - hw, py - hw, hw*2, hw*2);
            }
            ctx.shadowBlur = 0;
            ctx.font = `${TILE_SIZE * 0.46}px Arial`; ctx.textAlign = 'center'; ctx.fillText('🧊', px, py+7);
        } else if (this.type === 'defense') {
            ctx.shadowColor = tc; ctx.shadowBlur = fl ? 18 : 7;
            ctx.fillStyle = fl ? '#fff' : (isMe ? '#ddf0ff' : '#ffe8e8');
            ctx.strokeStyle = tc; ctx.lineWidth = 2.2;
            ctx.beginPath(); ctx.arc(px, py, TILE_SIZE*0.36, 0, Math.PI*2); ctx.fill(); ctx.stroke();
            ctx.shadowBlur = 0;
            ctx.save(); ctx.translate(px, py); ctx.rotate(this.angle || 0);
            ctx.fillStyle = isMe ? '#6ab8ff' : '#ff9090';
            if (ctx.roundRect) { ctx.beginPath(); ctx.roundRect(9, -4, 20, 9, 3); ctx.fill(); }
            else { ctx.fillRect(9, -4, 20, 9); }
            ctx.restore();
            ctx.font = `${TILE_SIZE * 0.36}px Arial`; ctx.textAlign = 'center'; ctx.fillText('🔫', px, py+5);
        } else if (this.type === 'soldier') {
            ctx.shadowColor = tc; ctx.shadowBlur = fl ? 14 : 4;
            ctx.fillStyle = fl ? '#fff' : (isMe ? '#4aa8e8' : '#e87070');
            ctx.strokeStyle = 'rgba(255,255,255,0.55)'; ctx.lineWidth = 1.8;
            ctx.beginPath(); ctx.arc(px, py-2, TILE_SIZE*0.24, 0, Math.PI*2); ctx.fill(); ctx.stroke();
            ctx.shadowBlur = 0;
            const legOffset = Math.sin(this.animationFrame * 2) * 5.5;
            ctx.strokeStyle = isMe ? '#2090d8' : '#d86060'; ctx.lineWidth = 2.8; ctx.lineCap = 'round';
            ctx.beginPath();
            ctx.moveTo(px - 5, py + 8); ctx.lineTo(px - 5 + legOffset, py + 18);
            ctx.moveTo(px + 5, py + 8); ctx.lineTo(px + 5 - legOffset, py + 18);
            ctx.stroke();
            ctx.font = `${TILE_SIZE * 0.28}px Arial`; ctx.textAlign = 'center'; ctx.fillText('⚔️', px, py + 4);
        } else if (this.type === 'arrow') {
            ctx.save(); ctx.translate(px, py); ctx.rotate(this.angle || 0);
            const sc = TILE_SIZE / 45; ctx.scale(sc, sc);
            ctx.shadowColor = fl ? '#fff' : '#ffe066'; ctx.shadowBlur = fl ? 18 : 13; 
            ctx.fillStyle = '#ffe066';
            ctx.beginPath(); ctx.moveTo(17, 0); ctx.lineTo(-11, -8); ctx.lineTo(-6, 0); ctx.lineTo(-11, 8); ctx.closePath(); ctx.fill();
            ctx.fillStyle = 'rgba(168,230,255,0.65)'; ctx.fillRect(-13, -1, 9, 2);
            ctx.shadowBlur = 0;
            ctx.restore();
        }

        if (this.hp < this.maxHp) {
            let hw = TILE_SIZE * 0.78; let hy = py - TILE_SIZE/2 - 13;
            ctx.beginPath();
            if(ctx.roundRect) ctx.roundRect(px - hw/2, hy, hw, 5, 3); else ctx.rect(px - hw/2, hy, hw, 5);
            ctx.fillStyle = 'rgba(200,50,50,0.65)'; ctx.fill();
            
            ctx.beginPath();
            if(ctx.roundRect) ctx.roundRect(px - hw/2, hy, hw * (this.hp/this.maxHp), 5, 3); else ctx.rect(px - hw/2, hy, hw * (this.hp/this.maxHp), 5);
            ctx.fillStyle = this.hp > this.maxHp * 0.4 ? '#5de8a8' : '#ffe066'; ctx.fill();
        }
    }
}

class GameEngine {
    constructor() {
        this.entities = []; this.particles = []; this.floatingTexts = []; this.projectiles = [];
        this.phase = 'lobby'; 
        this.offsetX = 0; this.offsetY = 0; this.flipY = false;
        this.maxMeHp = 1; this.maxOppHp = 1;
        canvas.addEventListener('click', (e) => this.handleClick(e));
        window.addEventListener('resize', () => this.resize());
        this.resize();
        requestAnimationFrame(() => this.loop());
    }

    resize() {
        width = window.innerWidth; height = window.innerHeight;
        canvas.width = width; canvas.height = height;

        if (width <= 768) {
            let availW = width - 40; let availH = height - 190;
            TILE_SIZE = Math.min(Math.floor(availW / COLS), Math.floor(availH / TOTAL_ROWS), 45);
        } else {
            TILE_SIZE = 45;
        }

        BOARD_W = COLS * TILE_SIZE; BOARD_H = TOTAL_ROWS * TILE_SIZE;
        this.offsetX = (width - BOARD_W) / 2;
        this.offsetY = (height - BOARD_H) / 2 + 10;
    }

    startPlacement() {
        this.phase = 'placement';
        this.entities = [new Entity(0, 3.5, 'red', 'main'), new Entity(9, 3.5, 'blue', 'main')];
        this.projectiles = []; this.particles = []; this.floatingTexts = [];
        canvas.classList.remove('zoom-battle');
        sfx.stopLobbyMusic(); 
    }

    prepareBattle(redBoard, blueBoard) {
        this.phase = 'reveal';
        this.entities = [new Entity(0, 3.5, 'red', 'main'), new Entity(9, 3.5, 'blue', 'main')];
        this.projectiles = [];

        const parseBoard = (boardObj, team, rowOffset) => {
            if(!boardObj) return;
            for(let i=0; i<40; i++) {
                let item = boardObj[i];
                if (item) {
                    let r = Math.floor(i / COLS) + rowOffset;
                    let c = i % COLS;
                    if (!((team === 'red' && r===0 && (c===3||c===4)) || (team==='blue' && r===9 && (c===3||c===4)))) {
                        this.entities.push(new Entity(r, c, team, item));
                    }
                }
            }
        };

        parseBoard(redBoard, 'red', 0);
        parseBoard(blueBoard, 'blue', 5);

        this.maxMeHp = this.entities.filter(e => e.team === gameApp.myRole).reduce((sum, e) => sum + e.maxHp, 0) || 1;
        this.maxOppHp = this.entities.filter(e => e.team !== gameApp.myRole).reduce((sum, e) => sum + e.maxHp, 0) || 1;
        addLog('❄️ All units deployed! Fight!', 'info');
    }

    spawnParticles(x, y, color, count, size=3, type='normal') {
        for(let i=0; i<count; i++) this.particles.push(new Particle(x, y, color, 3.5, size, type));
    }

    handleClick(e) {
        if (this.phase !== 'placement' || !gameApp.selectedUnit) return;

        let rect = canvas.getBoundingClientRect();
        let mouseX = e.clientX - rect.left - this.offsetX;
        let mouseY = e.clientY - rect.top - this.offsetY;

        let visual_r = Math.floor(mouseY / TILE_SIZE); let visual_c = Math.floor(mouseX / TILE_SIZE);
        let r = this.flipY ? (TOTAL_ROWS - 1 - visual_r) : visual_r;
        let c = visual_c;

        if (c < 0 || c >= COLS || r < 0 || r >= TOTAL_ROWS) return;

        let myRowStart = gameApp.myRole === 'blue' ? 5 : 0;
        let myRowEnd = gameApp.myRole === 'blue' ? 9 : 4;

        if (r >= myRowStart && r <= myRowEnd) {
            let localR = r - myRowStart;
            let gridIndex = (localR * COLS) + c;
            if (localR === (gameApp.myRole === 'blue'?4:0) && (c===3||c===4)) return;
            gameApp.placeUnit(gridIndex, r, c);
        }
    }

    triggerGameEnd(winnerTeam, reason) {
        if (this.phase === 'end' || this.phase === 'end_v') return;
        this.phase = 'end';
        update(ref(db, `matches/${gameApp.matchId}`), {
            status: 'finished', winnerRole: winnerTeam, endReason: reason
        });
    }

    triggerGameEndLocal(winnerTeam, reason) {
        if (this.phase === 'end_v') return;
        this.phase = 'end_v';
        setTimeout(() => gameApp.endGame(winnerTeam, reason), 2200);
    }

    loop() {
        if (this.phase === 'lobby') {
            ctx.clearRect(0, 0, width, height);
            requestAnimationFrame(() => this.loop());
            return;
        }

        ctx.fillStyle = 'rgba(200, 235, 255, 0.12)'; ctx.fillRect(0, 0, width, height);

        for (let r = 0; r < TOTAL_ROWS; r++) {
            for (let c = 0; c < COLS; c++) {
                let x = c * TILE_SIZE + this.offsetX; let y = r * TILE_SIZE + this.offsetY;
                const renderAsEnemyZone = this.flipY ? (r > 4) : (r < 5);
                if (renderAsEnemyZone) { 
                    ctx.fillStyle = 'rgba(255, 120, 120, 0.07)'; ctx.strokeStyle = 'rgba(220, 100, 100, 0.18)'; 
                } else { 
                    ctx.fillStyle = 'rgba(100, 180, 255, 0.07)'; ctx.strokeStyle = 'rgba(80, 160, 255, 0.18)'; 
                }
                ctx.lineWidth = 1.2;
                ctx.fillRect(x, y, TILE_SIZE, TILE_SIZE); ctx.strokeRect(x, y, TILE_SIZE, TILE_SIZE);
            }
        }

        // Draw Divider
        const midY = 5 * TILE_SIZE + this.offsetY;
        ctx.strokeStyle = 'rgba(255, 220, 80, 0.38)'; ctx.lineWidth = 1.8;
        ctx.setLineDash([7, 4]); ctx.beginPath(); ctx.moveTo(this.offsetX, midY); ctx.lineTo(this.offsetX + BOARD_W, midY); ctx.stroke(); ctx.setLineDash([]);
        
        // Zone Text
        ctx.globalAlpha = 0.11; ctx.font = `bold ${TILE_SIZE * 0.62}px 'Fredoka One'`; ctx.textAlign = 'center';
        ctx.fillStyle = this.flipY ? '#4488ff' : '#ff6060'; ctx.fillText('ENEMY', this.offsetX + BOARD_W / 2, this.offsetY + TILE_SIZE * 2.5);
        ctx.fillStyle = this.flipY ? '#ff6060' : '#4488ff'; ctx.fillText('YOUR ZONE', this.offsetX + BOARD_W / 2, this.offsetY + TILE_SIZE * 7.5); ctx.globalAlpha = 1;

        let sortedEntities = [...this.entities].sort((a, b) => {
            const ya = this.flipY ? (BOARD_H - a.y) : a.y;
            const yb = this.flipY ? (BOARD_H - b.y) : b.y;
            return ya - yb;
        });
        
        sortedEntities.forEach(e => {
            e.update(this);
            const origY = e.y;
            if (this.flipY) { e.y = BOARD_H - origY; }
            e.draw(ctx, this.offsetX, this.offsetY);
            if (this.flipY) { e.y = origY; }
        });

        for (let i = this.projectiles.length - 1; i >= 0; i--) {
            const p = this.projectiles[i]; p.update(this); 
            
            const origPY = p.y;
            if (this.flipY) p.y = BOARD_H - origPY;
            p.draw(ctx, this.offsetX, this.offsetY);
            if (this.flipY) p.y = origPY;

            if (p.life <= 0) this.projectiles.splice(i, 1);
        }

        if (this.phase === 'reveal' || this.phase === 'battle') {
            let currentMeHp = this.entities.filter(e => e.team === gameApp.myRole && !e.isDead).reduce((sum, e) => sum + e.hp, 0);
            let currentOppHp = this.entities.filter(e => e.team !== gameApp.myRole && !e.isDead).reduce((sum, e) => sum + e.hp, 0);

            let myPercentage = this.maxMeHp > 0 ? (currentMeHp / this.maxMeHp) * 100 : 0;
            let oppPercentage = this.maxOppHp > 0 ? (currentOppHp / this.maxOppHp) * 100 : 0;

            const bE = document.getElementById('b-str');
            const rE = document.getElementById('r-str');
            if (bE) bE.style.height = `${Math.max(0, myPercentage)}%`;
            if (rE) rE.style.height = `${Math.max(0, oppPercentage)}%`;
        }
        
        this.particles.forEach((p, i) => {
            p.update(); const origPY = p.y;
            if (this.flipY) p.y = BOARD_H - origPY;
            p.draw(ctx, this.offsetX, this.offsetY);
            if (this.flipY) p.y = origPY;
            if(p.life <= 0) this.particles.splice(i, 1);
        });

        this.floatingTexts.forEach((t, i) => {
            t.update(); const origTY = t.y;
            if (this.flipY) t.y = BOARD_H - origTY;
            t.draw(ctx, this.offsetX, this.offsetY);
            if (this.flipY) t.y = origTY;
            if(t.life <= 0) this.floatingTexts.splice(i, 1);
        });

        requestAnimationFrame(() => this.loop());
    }
}

const engine = new GameEngine();

