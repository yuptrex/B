const gameApp = {
    user: null, userData: { gold: 5000, grids: 50, streak: 0, username: "" },
    matchId: null, myRole: null,
    selectedUnit: null, selectedCost: 0,
    myBoard: Array(40).fill(null), oppBoard: Array(40).fill(null),
    timerInterval: null, queueRef: null, queueDisconnectRef: null, matchDisconnectRef: null,
    
    getSpent(board) {
        const c = {soldier: 10, barrier: 15, defense: 30, arrow: 50};
        return (board || []).reduce((sum, i) => sum + (c[i] || 0), 0);
    },

    switchScreen(id) { 
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active')); 
        document.getElementById('screen-game').classList.toggle('active', id === 'screen-game');
        if (id !== 'screen-game') document.getElementById(id).classList.add('active'); 
