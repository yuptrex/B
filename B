        <span class="field-lbl">SECRET PASSWORD</span>
      </div>
      <button class="btn btn-blue btn-bounce" id="btn-auth" onclick="gameApp.auth()" style="margin-top:4px;">
        <span id="auth-ic">❄️</span><span id="auth-tx">ENTER ICE KINGDOM</span>
      </button>
